{
  "name": "hr-assistant",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env node_modules/vite/bin/vite.js dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "start": "srvx serve --prod --dir . --entry dist/server/server.js --static dist/client",
    "test": "vitest run",
    "test:integration": "RUN_DB_TESTS=1 node --env-file-if-exists=.env node_modules/vitest/vitest.mjs run src/lib/ingest/ingest.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx --env-file-if-exists=.env scripts/migrate.ts",
    "seed": "tsx --env-file-if-exists=.env scripts/seed.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/ai": "^0.31.0",
    "@tanstack/ai-openrouter": "^0.13.4",
    "@tanstack/ai-react": "^0.15.8",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gpt-tokenizer": "^3.4.0",
    "lucide-react": "^0.545.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "srvx": "^0.11.16",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}