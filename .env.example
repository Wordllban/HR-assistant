# --- Required ---
# Get a free key at https://openrouter.ai/keys (≈60s). Used for BOTH chat and embeddings.
OPENROUTER_API_KEY=

# --- Database (defaults match docker-compose) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hr_assistant

# --- Models (free by default; swap on release without code changes) ---
# Chat model the assistant answers with. Override with any OpenRouter slug.
DEFAULT_CHAT_MODEL=openai/gpt-oss-120b:free
# Embedding model. NOTE: 2048-d — the chunks.embedding column is halfvec(2048).
# Changing the embedder's dimension requires re-indexing (re-run `pnpm seed`).
DEFAULT_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# Model used for conversational query condensation (defaults to DEFAULT_CHAT_MODEL).
CONDENSE_MODEL=

# --- Retrieval / chunking (sensible defaults; tune per corpus) ---
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.2
CHUNK_SIZE=600
CHUNK_OVERLAP=0.15
HISTORY_WINDOW=3

# --- App ---
APP_URL=http://localhost:3000
LOG_LEVEL=info

# --- Test-only: enables the local integration test (CI leaves this unset) ---
INTEGRATION_DB_URL=
